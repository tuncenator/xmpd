#!/usr/bin/env python3
"""xmpctl - Command-line client for xmpd sync daemon."""

# Auto-detect and use venv if available
import os
import sys
from pathlib import Path

_script_dir = Path(__file__).resolve().parent.parent
_venv_python = _script_dir / ".venv" / "bin" / "python"

if _venv_python.exists() and sys.executable != str(_venv_python):
    # Re-exec using venv Python
    os.execv(str(_venv_python), [str(_venv_python)] + sys.argv)

import json  # noqa: E402
import re  # noqa: E402
import socket  # noqa: E402
import subprocess  # noqa: E402
from typing import Any, NoReturn  # noqa: E402


def get_sync_socket_path() -> Path:
    """Get the Unix socket path for xmpd sync daemon.

    Returns:
        Path to the sync socket file.
    """
    config_dir = Path.home() / ".config" / "xmpd"
    return config_dir / "sync_socket"


def send_command(command: str) -> dict[str, Any]:
    """Send a command to the xmpd daemon and return the JSON response.

    Args:
        command: Command string to send to daemon

    Returns:
        Parsed JSON response as dict

    Raises:
        SystemExit: If connection fails or daemon returns error
    """
    socket_path = get_sync_socket_path()

    # Check if socket exists
    if not socket_path.exists():
        print("Error: xmpd daemon is not running", file=sys.stderr)
        print("Start the daemon with: python -m xmpd &", file=sys.stderr)
        sys.exit(1)

    try:
        # Connect to Unix socket
        sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        sock.connect(str(socket_path))

        # Send command
        sock.sendall((command + "\n").encode("utf-8"))

        # Receive response (read until newline)
        response = b""
        while True:
            chunk = sock.recv(4096)
            if not chunk:
                break
            response += chunk
            if b"\n" in response:
                break

        sock.close()

        # Parse JSON response
        response_text = response.decode("utf-8").strip()
        result = json.loads(response_text)

        return result

    except ConnectionRefusedError:
        print("Error: Failed to connect to daemon", file=sys.stderr)
        print("Make sure xmpd is running: python -m xmpd &", file=sys.stderr)
        sys.exit(1)
    except FileNotFoundError:
        print("Error: xmpd daemon socket not found", file=sys.stderr)
        print("Start the daemon with: python -m xmpd &", file=sys.stderr)
        sys.exit(1)
    except json.JSONDecodeError as e:
        print(f"Error: Invalid response from daemon: {e}", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)


def has_unicode_support() -> bool:
    """Check if terminal supports Unicode symbols.

    Returns:
        True if Unicode is supported, False otherwise.
    """
    # Check LANG environment variable for UTF-8
    lang = os.environ.get("LANG", "")
    return "UTF-8" in lang or "utf8" in lang


def has_color_support() -> bool:
    """Check if terminal supports ANSI color codes.

    Returns:
        True if colors are supported, False otherwise.
    """
    # Check if stdout is a TTY and TERM is set
    return sys.stdout.isatty() and os.environ.get("TERM", "dumb") != "dumb"


def colorize(text: str, color: str) -> str:
    """Colorize text if terminal supports it.

    Args:
        text: Text to colorize
        color: Color name (green, red, yellow, blue)

    Returns:
        Colored text or plain text if colors not supported
    """
    if not has_color_support():
        return text

    colors = {
        "green": "\033[32m",
        "red": "\033[31m",
        "yellow": "\033[33m",
        "blue": "\033[34m",
        "bold": "\033[1m",
        "reset": "\033[0m",
    }

    color_code = colors.get(color, "")
    reset_code = colors.get("reset", "")

    return f"{color_code}{text}{reset_code}"


def format_datetime(iso_str: str | None) -> str:
    """Format ISO datetime string to human-readable format.

    Args:
        iso_str: ISO format datetime string

    Returns:
        Formatted datetime or "Never" if None
    """
    if not iso_str:
        return "Never"

    # Simple formatting - just show date and time
    # Format: 2025-10-17T14:30:00Z -> 2025-10-17 14:30:00
    try:
        return iso_str.replace("T", " ").replace("Z", "")
    except Exception:
        return iso_str


def cmd_sync() -> None:
    """Trigger immediate sync."""
    print("Triggering sync...")
    result = send_command("sync")

    if result.get("success"):
        check = "✓" if has_unicode_support() else "OK"
        msg = result.get("message", "Sync triggered")
        print(colorize(f"{check} {msg}", "green"))
        print("Sync running in background. Use 'xmpctl status' to check progress.")
    else:
        cross = "✗" if has_unicode_support() else "ERROR"
        error = result.get("error", "Unknown error")
        print(colorize(f"{cross} {error}", "red"), file=sys.stderr)
        sys.exit(1)


def cmd_status() -> None:
    """Show sync status and statistics."""
    result = send_command("status")

    if not result.get("success"):
        print(colorize("Error getting status", "red"), file=sys.stderr)
        sys.exit(1)

    # Header
    print(colorize("=== xmpd Sync Status ===", "bold"))
    print()

    # Last sync time
    last_sync = format_datetime(result.get("last_sync"))
    print(f"Last sync: {last_sync}")

    # Daemon start time
    daemon_start = format_datetime(result.get("daemon_start_time"))
    print(f"Daemon started: {daemon_start}")

    # Per-provider authentication status
    prov_status = send_command("provider-status")
    if prov_status.get("success"):
        providers = prov_status.get("providers", {})
        for prov_name in ("yt", "tidal"):
            info = providers.get(prov_name)
            if info is None:
                continue
            label = f"Authentication ({prov_name})"
            if not info.get("enabled", False):
                print(f"{label}: {colorize('Disabled', 'yellow')}")
            elif info.get("authenticated", False):
                print(f"{label}: {colorize('Valid', 'green')}")
            else:
                print(f"{label}: {colorize('INVALID', 'red')}")
                print(f"  Run: {colorize(f'xmpctl auth {prov_name}', 'blue')} to authenticate")
    else:
        # Fall back to legacy single-provider field
        auth_valid = result.get("auth_valid", False)
        auth_error = result.get("auth_error", "")
        if auth_valid:
            print(f"Authentication: {colorize('Valid', 'green')}")
        else:
            print(f"Authentication: {colorize('INVALID', 'red')}")
            if auth_error:
                print(f"  Error: {auth_error}")
    print()

    # Sync in progress indicator
    if result.get("sync_in_progress"):
        print(colorize("Status: Sync in progress...", "yellow"))
    else:
        success = result.get("last_sync_success", False)
        if last_sync == "Never":
            print(colorize("Status: No sync performed yet", "yellow"))
        elif success:
            print(colorize("Status: Last sync successful", "green"))
        else:
            print(colorize("Status: Last sync had errors", "red"))
    print()

    # Statistics (only if we have sync results)
    if last_sync != "Never":
        print(colorize("=== Last Sync Statistics ===", "bold"))
        playlists_synced = result.get("playlists_synced", 0)
        playlists_failed = result.get("playlists_failed", 0)
        tracks_added = result.get("tracks_added", 0)
        tracks_failed = result.get("tracks_failed", 0)

        print(f"Playlists synced: {playlists_synced}")
        if playlists_failed > 0:
            print(colorize(f"Playlists failed: {playlists_failed}", "red"))

        print(f"Tracks added: {tracks_added}")
        if tracks_failed > 0:
            print(colorize(f"Tracks failed: {tracks_failed}", "yellow"))

        # Show errors if any
        errors = result.get("errors", [])
        if errors:
            print()
            print(colorize("=== Errors ===", "red"))
            for error in errors[:5]:  # Show max 5 errors
                print(f"  - {error}")
            if len(errors) > 5:
                print(f"  ... and {len(errors) - 5} more errors")


def cmd_list_playlists() -> None:
    """List playlists from all enabled providers."""
    print("Fetching playlists from all providers...")
    result = send_command("list")

    if not result.get("success"):
        error = result.get("error", "Unknown error")
        print(colorize(f"Error: {error}", "red"), file=sys.stderr)
        sys.exit(1)

    playlists = result.get("playlists", [])

    if not playlists:
        print("No playlists found.")
        return

    grouped: dict[str, list[dict[str, Any]]] = {}
    for p in playlists:
        grouped.setdefault(p.get("provider", "unknown"), []).append(p)

    provider_titles = {"yt": "YouTube Music", "tidal": "Tidal"}
    provider_prefixes = {"yt": "YT: ", "tidal": "TD: "}

    for prov_name in sorted(grouped):
        title = provider_titles.get(prov_name, prov_name.capitalize())
        prov_playlists = grouped[prov_name]
        print()
        print(colorize(f"=== {title} ({len(prov_playlists)}) ===", "bold"))
        print()
        for playlist in prov_playlists:
            name = playlist.get("name", "Unknown")
            track_count = playlist.get("track_count", 0)
            print(f"  - {name} ({track_count} tracks)")

    print()
    print(f"Total: {len(playlists)} playlists across {len(grouped)} provider(s)")
    print()
    print("To load a playlist in MPD, use:")
    for prov_name in sorted(grouped):
        prefix = provider_prefixes.get(prov_name, f"{prov_name.upper()}: ")
        print(colorize(f'  mpc load "{prefix}<playlist-name>"', "blue"))


def parse_provider_flag(args: list[str]) -> tuple[str | None, list[str]]:
    """Pop ``--provider <name>`` from *args*.

    Returns ``(provider_name_or_none, remaining_args)``.
    Handles both ``--provider yt`` and ``--provider=yt``.
    """
    remaining: list[str] = []
    provider: str | None = None
    it = iter(args)
    for tok in it:
        if tok == "--provider":
            provider = next(it, None)
        elif tok.startswith("--provider="):
            provider = tok.split("=", 1)[1]
        else:
            remaining.append(tok)
    return provider, remaining


# ANSI true color escapes for fzf output (consistent with bin/xmpd-status)
ANSI_TIDAL = "\033[38;2;115;218;202m"  # #73daca teal
ANSI_YT = "\033[38;2;247;118;142m"     # #f7768e pink
ANSI_RESET = "\033[0m"
ANSI_BOLD = "\033[1m"
ANSI_DIM = "\033[2m"


def format_track_fzf(track: dict[str, Any]) -> str:
    """Format a track dict as an ANSI-colored fzf display line.

    Output format: {provider}\\t{track_id}\\t{visible_colored_line}
    fzf uses --with-nth=3.. to show only the visible part.

    Args:
        track: Track dict with provider, track_id, title, artist, duration,
               quality, liked fields.

    Returns:
        Tab-separated line: provider, track_id, ANSI-colored display text.
    """
    provider = track.get("provider", "yt")
    track_id = track.get("track_id", "")
    title = track.get("title", "Unknown")
    artist = track.get("artist", "Unknown Artist")
    duration = track.get("duration", "0:00")
    quality = track.get("quality")
    liked = track.get("liked", False)

    if provider == "tidal":
        color = ANSI_TIDAL
        tag = "[TD]"
    else:
        color = ANSI_YT
        tag = "[YT]"

    # Quality badge
    badge = ""
    if quality in ("HR", "HiRes"):
        badge = f" {ANSI_BOLD}HiRes{ANSI_RESET}{color}"
    elif quality in ("CD", "LOSSLESS"):
        badge = " CD"
    elif quality == "320k":
        badge = " 320k"
    elif quality in ("Lo", "96k"):
        badge = f" {ANSI_DIM}Lo{ANSI_RESET}{color}"

    # Liked indicator
    liked_str = " [+1]" if liked is True else ""

    # Build visible line: [TD] CD [+1] Artist - Title (3:59)
    visible = (
        f"{color}{tag}{badge}{liked_str}"
        f" {artist} - {title} ({duration}){ANSI_RESET}"
    )

    return f"{provider}\t{track_id}\t{visible}"


def cmd_search_json(args: list[str]) -> None:
    """Output search results as NDJSON or fzf-formatted lines.

    Usage: search-json [--provider yt|all] [--limit N] [--format fzf] QUERY

    Args:
        args: Arguments after 'search-json' from sys.argv.
    """
    # Extract query and flags from args
    provider = "all"
    limit = 25
    output_format = "json"
    query_parts: list[str] = []
    i = 0
    while i < len(args):
        if args[i] == "--provider" and i + 1 < len(args):
            provider = args[i + 1]
            i += 2
        elif args[i] == "--limit" and i + 1 < len(args):
            try:
                limit = int(args[i + 1])
            except ValueError:
                pass
            i += 2
        elif args[i] == "--format" and i + 1 < len(args):
            output_format = args[i + 1]
            i += 2
        else:
            query_parts.append(args[i])
            i += 1

    query = " ".join(query_parts).strip()
    if not query:
        # For fzf format, exit silently on empty query (fzf sends empty on start)
        if output_format == "fzf":
            sys.exit(0)
        print("Error: search-json requires a query", file=sys.stderr)
        print("Usage: xmpctl search-json [--provider yt|all] [--limit N] QUERY", file=sys.stderr)
        sys.exit(1)

    # Skip single-char queries for fzf (debounce: too short to be useful)
    if output_format == "fzf" and len(query) < 2:
        sys.exit(0)

    # Build command string for daemon
    cmd_parts = ["search-json"]
    if provider != "all":
        cmd_parts += ["--provider", provider]
    cmd_parts += ["--limit", str(limit)]
    cmd_parts.append(query)
    command = " ".join(cmd_parts)

    result = send_command(command)

    if not result.get("success"):
        error = result.get("error", "Unknown error")
        print(f"Error: {error}", file=sys.stderr)
        sys.exit(1)

    tracks = result.get("results", [])
    if output_format == "fzf":
        for track in tracks:
            print(format_track_fzf(track))
    else:
        for track in tracks:
            print(json.dumps(track))


def cmd_play(provider: str, track_id: str) -> None:
    """Play a track immediately by clearing queue and starting playback.

    Args:
        provider: Provider canonical name (e.g. 'yt', 'tidal').
        track_id: Track identifier.
    """
    result = send_command(f"play {provider} {track_id}")
    if result.get("success"):
        message = result.get("message", "Playing...")
        print(colorize(f"OK {message}", "green"))
    else:
        error = result.get("error", "Failed to play")
        print(colorize(f"ERROR {error}", "red"), file=sys.stderr)
        sys.exit(1)


def cmd_queue(provider: str, track_id: str) -> None:
    """Add a track to the MPD queue.

    Args:
        provider: Provider canonical name (e.g. 'yt', 'tidal').
        track_id: Track identifier.
    """
    result = send_command(f"queue {provider} {track_id}")
    if result.get("success"):
        message = result.get("message", "Added to queue.")
        print(colorize(f"OK {message}", "green"))
    else:
        error = result.get("error", "Failed to add to queue")
        print(colorize(f"ERROR {error}", "red"), file=sys.stderr)
        sys.exit(1)


def cmd_radio(
    apply: bool = False,
    provider: str | None = None,
    track_id: str | None = None,
) -> None:
    """Generate radio playlist from currently playing track (or a given track).

    Args:
        apply: If True, automatically clear playlist, load radio, and play.
        provider: Force provider instead of inferring from current track.
        track_id: Seed track ID. If None, infers from currently playing track.
    """
    if track_id:
        print(f"Generating radio playlist from track {track_id}...")
    else:
        print("Generating radio playlist from current track...")
    cmd = "radio"
    if provider:
        cmd += f" --provider {provider}"
    if track_id:
        cmd += f" {track_id}"
    result = send_command(cmd)

    if result.get("success"):
        check = "✓" if has_unicode_support() else "OK"
        tracks = result.get("tracks", 0)
        playlist = result.get("playlist", "YT: Radio")
        radio_xspf = f"_xmpd/{playlist}.xspf"
        msg = f"Radio playlist created: {tracks} tracks"
        print(colorize(f"{check} {msg}", "green"))

        if apply:
            print()
            print("Applying radio playlist to MPD...")

            # Load config to get MPD connection info
            import yaml

            config_path = Path.home() / ".config" / "xmpd" / "config.yaml"
            mpd_socket = None
            mpd_port = 6600

            try:
                if config_path.exists():
                    with open(config_path) as f:
                        config = yaml.safe_load(f)
                        # Check for mpd_socket_path (can be Unix socket or host:port)
                        socket_path = config.get("mpd_socket_path")
                        if socket_path:
                            if ":" in socket_path and not socket_path.startswith("/"):
                                # It's a host:port format
                                _, port_str = socket_path.split(":", 1)
                                mpd_port = int(port_str)
                            else:
                                # It's a Unix socket path
                                mpd_socket = socket_path
                        # Fallback to separate host/port fields
                        elif "mpd_host" in config:
                            mpd_port = config.get("mpd_port", 6600)
            except Exception as e:
                print(colorize(f"Warning: Could not load config: {e}", "yellow"), file=sys.stderr)

            # Build mpc command
            if mpd_socket:
                # Unix socket connection
                mpc_cmd = ["mpc", "-h", mpd_socket]
            else:
                # TCP connection
                mpc_cmd = ["mpc", "-p", str(mpd_port)]

            try:
                # Clear current playlist
                subprocess.run(mpc_cmd + ["clear"], check=True, capture_output=True)

                # Load radio playlist from music directory
                # XSPF playlists are in music dir, not playlist dir
                subprocess.run(
                    mpc_cmd + ["load", radio_xspf], check=True, capture_output=True
                )

                # Start playback
                subprocess.run(mpc_cmd + ["play"], check=True, capture_output=True)

                print(colorize(f"{check} Radio playlist loaded and playing!", "green"))
            except subprocess.CalledProcessError as e:
                print(colorize(f"✗ Failed to apply radio playlist: {e}", "red"), file=sys.stderr)
                sys.exit(1)
        else:
            print()
            print(f"Playlist '{playlist}' is ready in MPD.")
            print("To load and play:")
            print(colorize(f'  mpc load "{radio_xspf}"', "blue"))
            print(colorize("  mpc play", "blue"))
            print()
            print("Or use:")
            print(colorize("  xmpctl radio --apply", "blue"))
    else:
        cross = "✗" if has_unicode_support() else "ERROR"
        error = result.get("error", "Unknown error")
        print(colorize(f"{cross} {error}", "red"), file=sys.stderr)
        sys.exit(1)


def get_mpd_connection_info() -> tuple[str | None, int]:
    """Get MPD connection info from config.

    Returns:
        Tuple of (socket_path, port). socket_path is None if using TCP.
    """
    import yaml

    config_path = Path.home() / ".config" / "xmpd" / "config.yaml"
    mpd_socket = None
    mpd_port = 6600

    try:
        if config_path.exists():
            with open(config_path) as f:
                config = yaml.safe_load(f)
                socket_path = config.get("mpd_socket_path")
                if socket_path:
                    if ":" in socket_path and not socket_path.startswith("/"):
                        # It's a host:port format
                        _, port_str = socket_path.split(":", 1)
                        mpd_port = int(port_str)
                    else:
                        # It's a Unix socket path
                        mpd_socket = socket_path
                elif "mpd_host" in config:
                    mpd_port = config.get("mpd_port", 6600)
    except Exception:
        pass  # Use defaults

    return mpd_socket, mpd_port


def _build_mpc_cmd() -> list[str]:
    """Build the base mpc command with connection args."""
    mpd_socket, mpd_port = get_mpd_connection_info()
    if mpd_socket:
        return ["mpc", "-h", mpd_socket]
    return ["mpc", "-p", str(mpd_port)]


def get_current_track_from_mpd() -> tuple[str, str, str, str]:
    """Get currently playing track from MPD.

    Returns:
        Tuple of (provider, track_id, title, artist).

    Raises:
        SystemExit: If no track is playing or track is not from a provider.
    """
    mpd_socket, mpd_port = get_mpd_connection_info()

    if mpd_socket:
        mpc_cmd = ["mpc", "-h", mpd_socket]
    else:
        mpc_cmd = ["mpc", "-p", str(mpd_port)]

    try:
        result = subprocess.run(
            mpc_cmd + ["current", "-f", "%file%"], capture_output=True, text=True, check=True
        )
        file_path = result.stdout.strip()

        if not file_path:
            print("Error: No track currently playing", file=sys.stderr)
            sys.exit(1)

        # New shape: /proxy/{provider}/{track_id}
        match = re.search(r"/proxy/([a-z]+)/([^/?]+)", file_path)
        if match:
            provider = match.group(1)
            track_id = match.group(2)
        else:
            # Legacy shape: /proxy/{11-char-yt-id}
            legacy = re.search(r"/proxy/([A-Za-z0-9_-]{11})$", file_path)
            if legacy:
                provider = "yt"
                track_id = legacy.group(1)
            else:
                print("Error: Current track is not a provider track", file=sys.stderr)
                sys.exit(1)

        # Get artist and title
        result = subprocess.run(
            mpc_cmd + ["current", "-f", "%artist%"], capture_output=True, text=True, check=True
        )
        artist = result.stdout.strip() or "Unknown Artist"

        result = subprocess.run(
            mpc_cmd + ["current", "-f", "%title%"], capture_output=True, text=True, check=True
        )
        title = result.stdout.strip() or "Unknown Title"

        return provider, track_id, title, artist

    except subprocess.CalledProcessError:
        print("Error: Failed to get current track from MPD", file=sys.stderr)
        print("Make sure MPD is running and a track is playing", file=sys.stderr)
        sys.exit(1)


def cmd_like() -> None:
    """Toggle like for current track via daemon round-trip."""
    provider, track_id, title, artist = get_current_track_from_mpd()

    result = send_command(f"like {provider} {track_id}")
    if result.get("success"):
        check = "OK"
        msg = result.get("message", "Liked")
        print(colorize(f"{check} {msg}: {artist} - {title}", "green"))
        # Trigger sync if the like state changed (so Liked Songs playlist updates)
        print("\nTriggering sync to update playlists...")
        sync_result = send_command("sync")
        if sync_result.get("success"):
            print(colorize("Sync started in background", "green"))
    else:
        cross = "ERROR"
        error = result.get("error", "Unknown error")
        print(colorize(f"{cross} {error}", "red"), file=sys.stderr)
        sys.exit(1)


def cmd_dislike() -> None:
    """Toggle dislike for current track via daemon round-trip."""
    provider, track_id, title, artist = get_current_track_from_mpd()

    result = send_command(f"dislike {provider} {track_id}")
    if result.get("success"):
        msg = result.get("message", "Disliked")
        print(f"{msg}: {artist} - {title}")
        print("\nTriggering sync to update playlists...")
        sync_result = send_command("sync")
        if sync_result.get("success"):
            print(colorize("Sync started in background", "green"))
    else:
        cross = "ERROR"
        error = result.get("error", "Unknown error")
        print(colorize(f"{cross} {error}", "red"), file=sys.stderr)
        sys.exit(1)


def cmd_like_toggle(provider: str, track_id: str) -> None:
    """Toggle like state for a specific track (used by fzf search ctrl-l).

    Args:
        provider: Provider canonical name (e.g. 'yt', 'tidal').
        track_id: Track identifier.
    """
    result = send_command(f"like-toggle {provider} {track_id}")
    if result.get("success"):
        msg = result.get("message", "Toggled")
        liked = result.get("liked", False)
        state_str = "[+1]" if liked else "[-1]"
        print(colorize(f"OK {state_str} {msg}", "green"))
    else:
        error = result.get("error", "Unknown error")
        print(colorize(f"ERROR {error}", "red"), file=sys.stderr)
        sys.exit(1)


def cmd_auth_tidal() -> None:
    """Run Tidal OAuth device flow and persist session token."""
    from xmpd.auth.tidal_oauth import run_oauth_flow
    from xmpd.exceptions import TidalAuthRequired

    session_path = Path.home() / ".config" / "xmpd" / "tidal_session.json"
    try:
        run_oauth_flow(session_path)
        check = "OK" if not has_unicode_support() else "✓"
        print(colorize(f"{check} Tidal authentication successful.", "green"))
        print(f"Token saved to: {session_path}")
        print()
        print("Next steps:")
        print(
            f"  1. Edit ~/.config/xmpd/config.yaml and set "
            f"{colorize('tidal.enabled: true', 'blue')}"
        )
        print(
            f"  2. Restart the daemon: "
            f"{colorize('systemctl --user restart xmpd', 'blue')}"
        )
    except TidalAuthRequired as e:
        cross = "ERROR" if not has_unicode_support() else "✗"
        print(colorize(f"{cross} Tidal authentication failed: {e}", "red"), file=sys.stderr)
        sys.exit(1)
    except KeyboardInterrupt:
        print("\nAuthentication cancelled", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        cross = "ERROR" if not has_unicode_support() else "✗"
        print(colorize(f"{cross} Unexpected error: {e}", "red"), file=sys.stderr)
        sys.exit(1)


def cmd_auth(provider: str, manual: bool = False) -> None:
    """Set up or refresh authentication for a provider.

    Args:
        provider: Provider canonical name ('yt', 'tidal').
        manual: If True for yt, use interactive browser-headers setup.
    """
    if provider == "yt":
        if manual:
            # Manual path: interactive ytmusicapi setup_browser
            from xmpd.providers.ytmusic import YTMusicClient

            try:
                YTMusicClient.setup_browser()
            except KeyboardInterrupt:
                print("\nAuthentication cancelled")
                sys.exit(1)
            except Exception as e:
                print(
                    colorize(f"Authentication failed: {e}", "red"),
                    file=sys.stderr,
                )
                sys.exit(1)
        else:
            # Cookie extraction path (was --auto, now the default for yt)
            from xmpd.auth.ytmusic_cookie import FirefoxCookieExtractor
            from xmpd.config import get_config_dir, load_config
            from xmpd.exceptions import CookieExtractionError

            try:
                config = load_config()
                auto_auth = config.get("yt", {}).get("auto_auth", {})

                extractor = FirefoxCookieExtractor(
                    browser=auto_auth.get("browser", "firefox-dev"),
                    profile=auto_auth.get("profile"),
                    container=auto_auth.get("container"),
                )

                output_path = get_config_dir() / "browser.json"
                extractor.build_browser_json(output_path)

                print(
                    colorize(
                        "OK browser.json updated from Firefox cookies.", "green",
                    )
                )
                print("Daemon will pick up new credentials automatically.")

            except CookieExtractionError as e:
                print(
                    colorize(f"ERROR Cookie extraction failed: {e}", "red"),
                    file=sys.stderr,
                )
                print(
                    "Make sure Firefox is running with an active Google session.",
                    file=sys.stderr,
                )
                sys.exit(1)
            except Exception as e:
                print(
                    colorize(f"ERROR Auto-auth failed: {e}", "red"),
                    file=sys.stderr,
                )
                sys.exit(1)

    elif provider == "tidal":
        cmd_auth_tidal()

    else:
        print(f"Unknown provider: {provider}", file=sys.stderr)
        sys.exit(1)


def show_help() -> None:
    """Display help message."""
    help_text = f"""{colorize("xmpctl", "bold")} - multi-provider music sync control

{colorize("Usage:", "bold")}
  xmpctl sync                    Trigger immediate sync
  xmpctl status                  Show sync status and statistics
  xmpctl list-playlists          List playlists from all providers

  xmpctl auth <provider>         Set up authentication for a provider
                                  Providers: yt, tidal
  xmpctl auth yt                 Auto-extract YouTube Music cookies from Firefox
  xmpctl auth yt --manual        Manual ytmusicapi browser-headers setup
  xmpctl auth tidal              Run Tidal OAuth device flow; persists token

  xmpctl play <provider> <id>    Play track immediately (clear queue, start playback)
  xmpctl queue <provider> <id>   Add track to MPD queue

  xmpctl search-json QUERY       Search and output NDJSON (for fzf integration)
                                  --provider yt|all  Restrict provider (default: all)
                                  --limit N          Max results (default: 25)
                                  --format fzf       ANSI-colored tab-separated fzf lines
  xmpctl radio [--apply]         Generate radio from current track (provider inferred)
                                  --provider <name>  Force provider
                                  --track-id <id>    Seed track ID (default: current track)
                                  --apply            Load and play immediately
  xmpctl like                    Toggle like for current track (provider inferred)
  xmpctl dislike                 Toggle dislike for current track (provider inferred)
  xmpctl like-toggle <prov> <id> Toggle like for specific track (used by fzf search)
  xmpctl help                    Show this help message

{colorize("Playback Control:", "bold")}
  Use mpc for playback control of synced playlists:
    mpc load "YT: Liked Songs"  Load YouTube playlist in MPD
    mpc load "TD: Favorites"    Load Tidal playlist in MPD
    mpc play                     Start playback
    mpc pause                    Pause playback
    mpc next                     Next track
    mpc prev                     Previous track
    mpc status                   Show playback status
    mpc current                  Show current track

{colorize("Configuration:", "bold")}
  Config file: ~/.config/xmpd/config.yaml
  Auth file:   ~/.config/xmpd/browser.json (or oauth.json)
  State file:  ~/.config/xmpd/sync_state.json

{colorize("Logs:", "bold")}
  Log file: ~/.config/xmpd/xmpd.log
"""
    print(help_text)


def main() -> NoReturn:
    """Main entry point for xmpctl client."""
    if len(sys.argv) < 2:
        show_help()
        sys.exit(0)

    command = sys.argv[1].lower()
    args = sys.argv[2:]

    # Dispatch commands
    if command == "sync":
        cmd_sync()
    elif command == "status":
        cmd_status()
    elif command == "list-playlists" or command == "list":
        cmd_list_playlists()
    elif command == "play":
        if len(args) < 2:
            print("Error: play requires <provider> <track_id>", file=sys.stderr)
            sys.exit(1)
        cmd_play(args[0], args[1])
    elif command == "queue":
        if len(args) < 2:
            print("Error: queue requires <provider> <track_id>", file=sys.stderr)
            sys.exit(1)
        cmd_queue(args[0], args[1])
    elif command == "radio":
        provider, remaining = parse_provider_flag(args)
        apply = "--apply" in remaining
        remaining = [a for a in remaining if a != "--apply"]
        # Parse --track-id flag
        track_id: str | None = None
        filtered: list[str] = []
        it = iter(remaining)
        for tok in it:
            if tok == "--track-id":
                track_id = next(it, None)
            elif tok.startswith("--track-id="):
                track_id = tok.split("=", 1)[1]
            else:
                filtered.append(tok)
        # Positional track_id if no --track-id flag
        if track_id is None and filtered:
            track_id = filtered[0]
        # Normalize: strip whitespace and treat empty strings as None.
        # fzf expands {1}/{2} to empty strings when no item is highlighted;
        # falling back silently to MPD's current track is wrong in that case.
        if provider is not None:
            provider = provider.strip() or None
        if track_id is not None:
            track_id = track_id.strip() or None
        # If --track-id was explicitly passed but resolved to empty, that is an
        # error -- do not silently fall back to the currently playing track.
        track_id_flag_given = any(
            a in ("--track-id",) or a.startswith("--track-id=") for a in args
        )
        if track_id_flag_given and track_id is None:
            print("Error: --track-id was given but resolved to an empty value", file=sys.stderr)
            sys.exit(1)
        cmd_radio(apply=apply, provider=provider, track_id=track_id)
    elif command == "search-json":
        cmd_search_json(args)
    elif command == "like":
        cmd_like()
    elif command == "dislike":
        cmd_dislike()
    elif command == "like-toggle":
        if len(args) < 2:
            print("Error: like-toggle requires <provider> <track_id>", file=sys.stderr)
            sys.exit(1)
        cmd_like_toggle(args[0], args[1])
    elif command == "auth":
        # Legacy compat: bare `auth` or `auth --auto` -> `auth yt`
        legacy_auto = "--auto" in args
        positional = [a for a in args if not a.startswith("--")]
        if not positional:
            # `auth` (no args) was manual; `auth --auto` was cookie
            auth_provider = "yt"
            manual = not legacy_auto
        else:
            auth_provider = positional[0]
            manual = "--manual" in args
        cmd_auth(auth_provider, manual=manual)
    elif command in ("help", "--help", "-h"):
        show_help()
    else:
        print(f"Error: Unknown command: {command}", file=sys.stderr)
        print("Run 'xmpctl help' for usage information", file=sys.stderr)
        sys.exit(1)

    sys.exit(0)


if __name__ == "__main__":
    main()
